# Camera
CAMERA_INDEX=0
FRAME_SKIP=5

# OCR
BUFFER_SIZE=3
CONFIDENCE_MIN=0.5

# Plate
PLATE_MIN_LENGTH=2
PLATE_MAX_LENGTH=11
PLATE_SPECIAL_MIN=5

# Timeout
NO_PLATE_TIMEOUT=5

# Laravel API (set LARAVEL_ENABLED=true when ready)
LARAVEL_ENABLED=true
LARAVEL_API_URL=http://condo-pass.test/api/scanned-plate
LARAVEL_API_TOKEN=your-api-token-here